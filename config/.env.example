# 基金TA每日简报系统 — 环境变量配置
# 复制本文件为 .env 并填入真实值
# 注意：.env 文件不要提交到 Git！

# DeepSeek API Key（用于生成摘要）
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 发件邮箱（用于推送简报）
EMAIL_ADDRESS=your_email@example.com

# 邮箱授权码（非登录密码，需在邮箱设置中开启SMTP并获取）
EMAIL_PASSWORD=your_email_authorization_code

# SMTP 服务器配置（以下为常用邮箱示例，选择对应的填入）
# 126邮箱:  smtp.126.com  端口465
# 163邮箱:  smtp.163.com  端口465
# QQ邮箱:   smtp.qq.com   端口465
# Gmail:    smtp.gmail.com 端口587
SMTP_SERVER=smtp.126.com
SMTP_PORT=465
